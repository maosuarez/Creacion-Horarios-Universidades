# ===========================================================
# ENTORNO GLOBAL — creacion-horarios
# Copia este archivo a .env y rellena los valores.
# NUNCA commitees el .env con valores reales.
# ===========================================================

# Entorno: local | production
# Usar "local" para desarrollo (CORS abierto, tablas auto-creadas).
# Cambiar a "production" en servidor real.
ENV=local

# -------- Puertos expuestos al host --------
# El puerto interno del contenedor siempre es 3000/8000.
# Cambiar estos si hay conflictos con otros servicios en el host.
FRONTEND_PORT=3000
BACKEND_PORT=8000

# -------- Frontend (Next.js) --------
# IMPORTANTE: esta URL la usa el NAVEGADOR del cliente, no el contenedor Docker.
# Debe ser alcanzable desde la máquina del usuario final.
#   Local / Docker en tu PC:  http://localhost:8000
#   Producción:               https://api.tudominio.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# CORS: origen permitido del frontend (lo lee el backend cuando ENV != local)
FRONTEND_URL=http://localhost:3000

# -------- Auth (JWT) --------
SECRET_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -------- Base de datos (producción: MySQL) --------
DB_ENGINE=mysql
DB_USER=horarios_user
DB_PASS=cambia-esta-password
DB_NAME=horarios
MYSQL_ROOT_PASSWORD=cambia-esta-root-password

# Conexión MySQL.
# DB_HOST=db      → cuando el backend corre dentro de Docker Compose (nombre del servicio).
# DB_HOST=localhost → cuando el backend corre fuera de Docker (directo con uvicorn).
DB_HOST=db
DB_PORT=3306

# SSL para MySQL (opt-in).
# Dejar vacío para MySQL local sin SSL (Docker Compose local).
# Definir la ruta al certificado solo si tu proveedor MySQL lo requiere (ej. Azure).
DB_SSL_CA=

# -------- Base de datos (desarrollo: SQLite) --------
# Usado solo con docker-compose.dev.yml (DB_ENGINE=sqlite en el override)
SQLITE_PATH=/app/data/dev.db
